{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/bin/fm-arm-pretool-check.sh --claude"
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/bin/fm-cd-pretool-check.sh --claude"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/bin/fm-turnend-guard.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bin/fm-bearings-snapshot.sh *)",
      "Bash(bin/fm-review-diff.sh *)",
      "Bash(bin/fm-crew-state.sh *)",
      "Bash(quota-axi)",
      "Bash(bin/fm-peek.sh *)",
      "Bash(bin/fm-project-mode.sh *)",
      "Bash(treehouse status)",
      "Bash(no-mistakes doctor)",
      "Bash(no-mistakes axi status)"
    ]
  }
}
